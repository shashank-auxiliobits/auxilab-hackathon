# AP Invoice Intelligence — environment configuration
# Copy to `.env` for local development. NEVER commit a populated .env.
# All variables are prefixed with AP_.

# --- Runtime ---
AP_ENVIRONMENT=development          # development | staging | production | test
AP_LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR
AP_LOG_JSON=false                   # true in production, false for readable local logs

# --- Database (async DSN; must use the +asyncpg driver) ---
# Leave AP_DATABASE_URL UNSET to use the sensible default:
#   - app run on the host          -> localhost:5432
#   - docker --profile bundled-db  -> the bundled 'postgres' container
# For an EXTERNAL / managed database (RDS, Cloud SQL, Neon, Supabase, ...),
# uncomment and set your async connection string:
# AP_DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/DBNAME
AP_DB_POOL_SIZE=10
AP_DB_MAX_OVERFLOW=20
AP_DB_ECHO=false

# --- REST API ---
AP_API_HOST=0.0.0.0
AP_API_PORT=8000
AP_API_ROOT_PATH=
AP_CORS_ALLOW_ORIGINS=              # comma-separated, e.g. https://app.example.com
AP_RATE_LIMIT=120/minute

# --- Security ---
# REQUIRED, no default — the app will not start unless these are set.
# Generate each with: python -c "import secrets; print(secrets.token_urlsafe(48))"
# Server-side pepper mixed into every API-key and password hash (>= 16 chars).
AP_API_KEY_PEPPER=

# --- Auth: users, sessions, email-OTP verification ---
# Secret used to sign session JWTs (>= 32 chars). REQUIRED, no default.
AP_JWT_SECRET=
AP_JWT_EXPIRE_MINUTES=60
AP_PASSWORD_MIN_LENGTH=8
AP_OTP_LENGTH=6
AP_OTP_TTL_MINUTES=10
AP_OTP_MAX_ATTEMPTS=5

# --- Email delivery (OTP verification) ---
# console = log the OTP to the server console (default, works out of the box, no creds).
# smtp    = send a real email (set AP_EMAIL_BACKEND=smtp and the AP_SMTP_* values).
# Gmail example: HOST=smtp.gmail.com PORT=587 USE_TLS=true,
#   USERNAME=you@gmail.com, PASSWORD=<16-char Google App Password> (needs 2-Step Verification).
# Other providers (SendGrid/SES/Mailgun) drop into the same four AP_SMTP_* vars.
AP_EMAIL_BACKEND=console
AP_EMAIL_FROM=no-reply@ap-invoice.local
AP_SMTP_HOST=
AP_SMTP_PORT=587
AP_SMTP_USERNAME=
AP_SMTP_PASSWORD=
AP_SMTP_USE_TLS=true

# --- MCP server ---
AP_MCP_HOST=0.0.0.0
AP_MCP_PORT=8080
AP_MCP_TRANSPORT=streamable-http    # streamable-http | stdio
# Only used for the stdio transport (no HTTP headers): the org API key tool
# calls are scoped to. Over streamable-HTTP, clients send their own key.
AP_MCP_API_KEY=

# --- LLM provider (mandatory) ---
# One multimodal provider handles BOTH invoice extraction (vision) and the
# RAG + approval decision. Choose claude, openai, or gemini.
AP_LLM_PROVIDER=claude              # claude | openai | gemini

# Claude (default).
AP_ANTHROPIC_API_KEY=               # required when AP_LLM_PROVIDER=claude
AP_CLAUDE_MODEL=claude-opus-4-8

# GPT / OpenAI-compatible.
AP_OPENAI_API_KEY=                  # required when AP_LLM_PROVIDER=openai
AP_OPENAI_BASE_URL=                 # blank → api.openai.com
AP_OPENAI_MODEL=gpt-4o

# Gemini / Google AI Studio.
AP_GEMINI_API_KEY=                  # required when AP_LLM_PROVIDER=gemini
AP_GEMINI_MODEL=gemini-2.5-flash


# Shared LLM call limits (extraction + decision).
AP_EXTRACTOR_MAX_TOKENS=4096
AP_EXTRACTOR_TIMEOUT_SECONDS=60

# --- Extraction input limits (multi-file uploads) ---
AP_MAX_FILE_BYTES=10485760          # max decoded size per uploaded file (10 MiB)
AP_MAX_FILES_PER_INVOICE=10         # max files accepted per invoice
AP_MAX_EXTRACTION_IMAGES=16         # max image parts (PDF pages + images) sent per extraction
AP_DUPLICATE_CANDIDATE_LIMIT=1000   # recent invoices scanned as duplicate candidates

# --- Autonomy (touchless processing) ---
# LLM-extracted invoices below this per-field confidence are held for review.
AP_MIN_EXTRACTION_CONFIDENCE=0.6    # 0.0 - 1.0

# --- RAG / embeddings (vendor policy retrieval) ---
AP_EMBEDDING_PROVIDER=local         # 'local' = deterministic offline embedder
AP_EMBEDDING_DIM=256
AP_RAG_CHUNK_SIZE=1200              # target policy chunk size, in characters
AP_RAG_TOP_K=6                     # policy chunks retrieved per decision
AP_POLICY_COMPILER_MAX_TOKENS=4096

# --- Docker compose only (Postgres container; not read by the app) ---
# These configure the bundled Postgres service in docker-compose.yml.
POSTGRES_USER=ap
POSTGRES_PASSWORD=ap_password
POSTGRES_DB=ap_invoice
